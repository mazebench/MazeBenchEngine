# Keep the build context small and avoid copying host-specific or heavy dirs.
# The container only needs top-level scripts/, server/, public/, games/ and the
# JS package manifests; everything else below is excluded.
.git
node_modules
.venv
outputs
**/outputs
**/__pycache__
*.log
.DS_Store
dist
build
# Not needed at runtime by the local-agent path:
environments
tests
docs
mazebench_cli
.prime
.codex
.claude
.github
